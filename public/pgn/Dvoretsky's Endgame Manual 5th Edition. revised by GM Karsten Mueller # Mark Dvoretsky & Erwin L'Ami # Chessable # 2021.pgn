1. a4 g5
{ But @@StartFEN@@8/1p1b2p1/1p3p1p/2kp4/P4PP1/1PK1PB1P/8/8 b - - 2 3@@EndFEN@@  3...h5!  draws. For example,  4.b4+  Kd6  5.Bd1  h4  6.Bc2  g6  7.Kd4  b5  8.a5  f5  , and if  5.Kd4  hxg4  6.hxg4  Bxa4  7.Bxd5  Bc6  8.Bc4  g5= }
