[White "Panov-Botvinnik Attack"]
[Black "Quick-Starter "]
[Result "*"]
[ECO "D94"]
[Annotator "Ostrovskiy, Aleksandr"]
[PlyCount "70"]
[EventDate "2017.??.??"]
