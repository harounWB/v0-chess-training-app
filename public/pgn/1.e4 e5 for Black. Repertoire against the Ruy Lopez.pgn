{[%evp 0,82,21,17,40,27,27,21,31,1,22,20,8,-6,73,-15,18,4,31,37,37,-5,13,18,-5,-4,20,21,33,29,21,24,23,-31,-9,-21,-6,-18,-10,-13,17,-14,-39,-37,-20,-10,-1,-29,-11,-86,-47,-57,-59,-59,-42,-69,-120,-166,-174,-182,-174,-186,-203,-203,-200,-232,-208,-232,-213,-190,-189,-186,-145,-221,-168,-183,-131,-163,-21,-85,-16,-205,-116,-125,-121]} 1. e4 e5 2. Nf3 Nc6 3. Bb5 a6 4. Ba4 d6 5. O-O Nf6 6. Re1 g6 7. c3 Bd7 8. d4 b5 9. Bb3 Bg7 10. Bg5 h6 11. Bh4 O-O 12. h3 Re8 13. Nbd2 Na5 14. Bc2 c5 15. d5 c4 16. g4 $2 (16. b4 cxb3 17. axb3 Qc7 18. Re3 Nb7 19. b4 Nh5 $1 $36 (19... a5)) (16. b4 cxb3 17. axb3 Qc7 18. Re3 Nh5) (16. a4 Qc7) 16... Qc7 $1 17. Nf1 (17. b4 cxb3 18. axb3 Qxc3) (17. a4 $2 Nb7 $17) 17... Nb7 18. Ne3 Nc5 19. Nd2 $15 Nh7 $1 (19... a5 $1 20. a4 bxa4 21. Nexc4 h5 $3 22. Bxf6 Bxf6 23. gxh5 Kg7 $3 24. hxg6 fxg6 $19) 20. Qf3 Ng5 (20... Rf8 21. Be7 Bxg4) 21. Qg2 Bf6 22. Bg3 Nh7 23. Nf3 Bg7 (23... a5 $1 $15) 24. h4 Nf6 $15 25. Nh2 a5 $1 26. f3 b4 $1 $17 27. Rac1 b3 $1 28. axb3 (28. Bb1 bxa2 29. Bc2 (29. Bxa2 Nd3) 29... Nb3 30. Bxb3 cxb3) 28... cxb3 29. Bb1 a4 $19 30. c4 a3 31. bxa3 Rxa3 32. Nd1 Qb6 33. Bf2 Ra1 34. Nb2 Qc7 35. Nf1 Rea8 36. Nd2 h5 37. g5 Ne8 38. Kh1 Qb7 39. Qf1 Bf8 40. Bd3 Rxc1 41. Rxc1 Qb4 $3 $19 *

