{[%evp 0,103,36,33,40,40,25,25,36,4,14,28,39,4,25,24,21,-12,-1,5,1,-28,19,15,14,35,39,25,47,29,34,-14,31,12,49,24,24,16,47,43,31,25,50,4,31,7,30,6,15,13,25,29,35,15,0,0,0,-49,-3,-5,-21,-21,-32,-37,-20,-70,33,49,43,45,48,-28,57,70,64,58,91,50,67,61,88,66,69,62,78,102,116,100,155,191,201,238,290,290,288,312,1006,1075,1078,392,420,461,443,509,29999,-30000]} 1. e4 e5 2. Nf3 Nc6 3. Bb5 a6 4. Ba4 d6 5. d4 Bd7 6. dxe5 Nxe5 (6... dxe5 $1 7. O-O Bd6 8. c3 Nge7 $132 (8... Nf6 $132)) 7. Bxd7+ Qxd7 8. Nxe5 dxe5 9. Qxd7+ {This is an equal endgame but both sides can play for a win!} Kxd7 10. O-O Bd6 (10... Nf6 $1 11. f3 $2 (11. Re1 Ke6 12. Nd2 Nd7 13. a3 (13. b3 Bb4) 13... b5 14. Nf3 f6 15. Bd2 Bd6 $132) 11... Bc5+ 12. Kh1 Ke6 13. Nc3 Rhd8 14. Bg5 c6 $15) 11. Nc3 Ne7 12. Be3 Nc6 13. Nd5 Rhe8 14. a3 Rad8 15. c4 Kc8 16. b4 Ne7 17. c5 Nxd5 18. exd5 Bf8 19. Rfd1 f5 20. f3 Rd7 21. Rd2 h6 22. Rad1 e4 23. f4 Be7 24. h3 Bf6 25. g4 g6 26. Kf1 h5 27. gxf5 gxf5 28. Rg2 Rg7 29. Rxg7 Bxg7 30. Kf2 Bb2 31. a4 Rg8 32. d6 Rg6 33. Rd5 Rf6 34. dxc7 Kxc7 35. Ke2 Bc3 36. b5 axb5 37. axb5 Bb2 38. Kd1 Rf7 39. Kc2 Bg7 40. Kb3 Kc8 41. Kc4 Kc7 42. b6+ Kc8 43. Rd6 Bf8 44. Rg6 Kd7 45. Kd5 Be7 46. c6+ bxc6+ 47. Rxc6 Rf8 48. Rc7+ Kd8 49. Ra7 Rf6 50. Bd4 Rd6+ 51. Ke5 Rd7 52. Ra8# 1-0

