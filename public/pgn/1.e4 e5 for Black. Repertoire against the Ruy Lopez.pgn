{[%evp 0,71,33,40,41,32,36,33,33,-4,14,29,52,40,35,12,5,28,75,22,31,18,26,32,76,47,41,23,33,27,31,15,47,2,59,37,36,28,28,2,33,21,58,67,37,65,69,73,74,46,55,-149,70,56,61,45,31,-122,72,33,296,88,198,54,76,25,168,106,94,26,583,-55,-51,-112]} 1. e4 e5 2. Nf3 Nc6 3. Bb5 a6 4. Ba4 d6 5. d4 Bd7 $1 {Again this move avoids repetitions after 5...ed4!?. Black wants to play a position with a closed centre.} 6. d5 (6. c3 g6 7. Bg5 Be7 8. Be3 Nf6 9. Nbd2 Ng4 $132) (6. O-O Nf6 7. Re1 b5 8. Bb3 Nxd4 9. Nxd4 exd4 $15) 6... Nce7 7. c4 b5 8. Bc2 g6 9. a4 Bg7 (9... bxc4 10. Na3 Bg7 11. Nxc4 f5 $132) 10. Nc3 b4 11. Ne2 h5 $2 (11... f5 $1 $15) 12. a5 c5 13. dxc6 Bxc6 14. Bg5 Nf6 15. Ng3 Qc7 16. Qd2 Rb8 (16... b3 $5) 17. O-O Nd7 18. Rfd1 Nc8 19. h4 Nc5 20. b3 Bd7 21. Ne1 Ne6 22. Be3 Bf6 23. Nf3 Nc5 24. Nf1 Bg4 25. N3h2 Bd7 26. g3 Rb7 27. Nf3 Bg4 28. N3h2 Bd7 29. Nf3 Na7 30. Bxc5 Qxc5 31. Ne3 Nc6 32. Qd5 Bg4 33. Nxg4 hxg4 34. Ne1 Nd4 35. Rd3 Qxd5 36. exd5 0-1

