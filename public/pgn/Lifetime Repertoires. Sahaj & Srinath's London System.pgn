[White "Thematic Ideas "]
[Black "Sadhwani, Raunak vs. Bouget, Alexandre, 2021"]
[Result "*"]
[FEN "r4rk1/p1qn1ppp/bp1bp3/2ppN3/3PnB2/2P1PN1Q/PPB2PPP/R3K2R w KQ - 0 13"]
