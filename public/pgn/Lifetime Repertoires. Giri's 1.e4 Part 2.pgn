5. Nc3
{ Transposing to the Pirc @@StartBracket@@ @@StartFEN@@rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1@@EndFEN@@  1.e4  d6  2.d4  Nf6  3.Nc3  g6  4.Nf3  Bg7  5.Be2  @@EndBracket@@. }
