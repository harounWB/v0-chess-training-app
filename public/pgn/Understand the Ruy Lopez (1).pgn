{[%evp 0,132,19,28,23,21,18,4,13,22,18,20,16,14,25,7,7,13,23,23,17,24,24,9,16,
17,9,7,4,5,5,1,3,-16,-24,-25,-21,-31,-62,-95,-95,-80,-95,-94,-98,-103,-97,-81,
-78,-112,-82,-82,-147,-146,-146,-146,-148,-182,-102,-93,-90,-99,-110,-108,-137,
