[Event "Lodz 1916/17"]
[Site "Lodz"]
[Date "1916.??.??"]
[Round "?"]
[White "Factor, Samuel D"]
[Black "Rubinstein, Akiba"]
[Result "0-1"]
[ECO "C68"]
[Annotator "GM Petar G. Arnaudov"]
