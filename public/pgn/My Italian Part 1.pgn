{[%evp 0,127,30,23,25,23,23,15,15,15,22,22,26,8,14,-2,-5,-29,-20,-29,-27,-28,-26,-26,-29,-29,-33,-21,-21,-21,-22,-28,-20,-41,-32,-27,-26,-28,-21,-17,-9,0,2,13,59,34,31,38,34,36,45,14,26,37,51,54,51,55,55,58,58,58,58,54,54,50,55,50,69,70,73,72,71,64,62,62,72,64,68,68,68,68,64,0,68,64,64,64,79,64,79,64,79,64,64,49,48,0,68,64,64,64,64,64,64,27,29,27,31,55,17,53,0,0,0,106,110,90,187,187,171,179,175,173,217,209,379,398,429,429]} 1. e4 e5 2. Nf3 Nc6 3. Bc4 Nf6 4. d3 h6 5. Nc3 Bc5 6. h3 d6 7. Na4 Bb6 8. a3 Be6 9. Bxe6 fxe6 10. b4 O-O 11. O-O Qe8 12. c4 $6 {It's premature because now Black can use the d4 square to generate counterplay. Be cautious about this.} (12. c3 {is more precise. We have already examined this theoretical position.}) 12... Nd4 $6 (12... Bd4 $11) 13. Nxb6 Nxf3+ 14. Qxf3 axb6 15. Qe2 $14 Qg6 16. Ra2 Nh5 17. Qg4 Kh7 18. Qxg6+ Kxg6 19. a4 Nf6 20. Be3 $14 Nd7 21. Rfa1 Nb8 22. a5 bxa5 23. Rxa5 Rxa5 24. Rxa5 Na6 25. b5 Nb4 26. Ra3 c5 27. Bd2 Nc2 28. Ra7 Rf7 29. f3 Rd7 30. Kf2 Kf6 31. Ra2 Nd4 32. Bc3 d5 33. Ra8 dxc4 34. dxc4 b6 35. Ra6 Rb7 36. Ke3 g5 37. Kd3 h5 38. Be1 h4 39. Bf2 Kf7 40. Be3 Kf6 41. Bd2 Nb3 42. Bc3 Nd4 43. Ra8 Rd7 44. Ke3 Rb7 45. Kf2 Nb3 46. Ra3 Nd4 47. Bd2 Rd7 48. Bc1 Rd8 49. Ra6 Rb8 50. Ra7 Kg6 51. Be3 Kf6 52. g3 Kg6 53. Ra6 Rb7 54. Ra8 Rf7 55. Bxd4 cxd4 56. gxh4 gxh4 57. Rb8 Rc7 58. Rxb6 Rxc4 59. Rxe6+ Kf7 60. Rxe5 Rc2+ 61. Kf1 Rc3 62. Ke2 Rc2+ 63. Kd3 Rc3+ 64. Kxd4 1-0

