{[%evp 0,86,31,38,44,41,74,55,64,64,53,22,84,76,69,65,66,46,46,48,76,42,32,15,
24,1,16,-43,-43,-43,1,-16,-43,-46,-44,-80,-94,-119,-44,-66,-62,-100,-106,-106,
-68,-84,-29,-10,-11,-18,-16,-15,-20,-35,-59,-213,-205,-186,-225,-237,-224,-228,
-193,-181,-179,-334,-281,-350,-243,-328,-345,-331,-255,-288,-266,-321,-318,
