{[%evp 0,77,12,27,83,76,69,69,65,62,67,49,66,61,70,54,35,25,5,5,-7,-10,-1,0,0,-19,-4,-23,-13,-50,-45,-74,-43,-37,-28,-52,-67,-73,-81,-75,-38,-40,0,-21,-15,-21,0,-36,-23,-27,-26,-25,-8,-12,-14,-21,-14,-37,-28,-20,-38,-35,-43,-41,-47,-52,-47,-37,-38,0,0,0,-13,-13,-22,-34,-20,-1018,-1018,-1523] [#]} {Black to move} 5... Bxc3+ 6. bxc3 Nc6 {[%csl Rc3][%cal Gd7d6,Ge6e5] d6-e5 will be coming and the c3 pawn is awful. White was 2 bishops but the positions remains closed. We could secure the queenside later on with Qe7-Bd7-b6 and we'll be on the drivers seat!} *

