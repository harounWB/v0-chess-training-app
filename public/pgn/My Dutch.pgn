{[%evp 0,48,27,27,70,52,72,77,95,44,35,24,24,12,12,20,10,-14,-13,-7,11,5,24,-3,11,17,20,18,21,12,-10,0,0,2,-9,-30,-47,-72,-79,-137,-137,-126,-133,-90,-81,-149,-161,-264,-296,-290,-276] [#]} {Black to move} 8... e5 $1 {[%csl Gc6,Gf3] This is why including Nc6 and Nf3 makes a huge difference!} 9. dxe5 Bf5 $132 {[%cal Gd6e5] Will take on e5 and i'd say black is more than comfortable here and our play is pretty easy from now on.} *

