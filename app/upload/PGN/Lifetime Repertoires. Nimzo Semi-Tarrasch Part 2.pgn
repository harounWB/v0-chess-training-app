[White "Chapter 28: dxc5 Endgame (9.Nbd2-11.Nb3 Be7 12.Nfd4)"]
[Black "dxc5 endgame 9.Nbd2-11.Nb3 Be7 12.Nfd4 #2"]
[Result "*"]

