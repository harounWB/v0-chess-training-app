{[%evp 0,33,21,16,39,22,17,8,60,47,43,41,41,50,45,7,-1,-9,-10,-12,13,9,-1,2,12,
33,34,-77,-58,-58,-33,-14,-7,-7,12,4]} 1. e4 e5 2. Nf3 Nc6 3. Bb5 d6 {This is
the Steinitz variation. The line with a6 and Ba4 included is a better version
