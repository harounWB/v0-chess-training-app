{[%evp 0,45,32,20,20,20,20,20,20,24,29,6,21,5,27,14,-10,-49,-40,-80,-69,-295,
-278,-302,-302,-300,-227,-155,-177,-231,-225,-214,-214,-214,-111,-115,-89,-164,
