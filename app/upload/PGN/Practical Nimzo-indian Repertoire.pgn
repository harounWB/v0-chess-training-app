{[%evp 0,117,28,14,14,0,0,-3,33,3,3,-7,10,-23,8,5,31,-14,-7,-8,-8,-55,-18,-10,
18,-16,30,24,39,-6,-6,-11,39,-25,-30,-16,-24,-4,-22,-7,-8,-20,-2,-27,-24,-34,
