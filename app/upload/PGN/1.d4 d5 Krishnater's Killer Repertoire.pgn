[Site "?"]
[Date "????.??.??"]
[Round "?"]
[White "12) Catalan - Main Line with 9.Nfd2"]
[Black "9.Nfd2 Nd5 10.e4 "]
[FEN "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1"]
