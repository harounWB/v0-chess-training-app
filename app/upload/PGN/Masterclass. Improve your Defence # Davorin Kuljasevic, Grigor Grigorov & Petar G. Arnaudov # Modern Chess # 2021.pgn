[ECO "E15"]
[WhiteElo "2590"]
[BlackElo "2786"]
[Annotator "GM Grigor Grigorov"]
[SetUp "1"]
[FEN "r2nk2r/p3bppp/1pp5/3qP3/Q2P4/5NP1/P2B1PKP/R1R5 b kq - 0 17"]
