[White "Section I - General Principles"]
[Black "Principles in Action 9.2 - Controlling the Center III"]
[Result "*"]
[FEN "r1bk1bnr/1p1p1ppp/p2P1qn1/1N6/5P2/4B3/PPP3PP/R2QKB1R w KQ - 0 1"]
