[White "4...Bc5 5.Bxc6 dxc6 6.O-O Qe7 − 10.a3 Sidelines"]
[Black "4...Bc5 5.Bxc6 dxc6 6.O-O Qe7 7.Nbd2 Bg4 8.h3 h5"]
