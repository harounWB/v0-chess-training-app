[White "Space Advantage for Black"]
[Black "?"]
[Result "*"]
[Annotator "GM Grigor Grigorov"]
[SetUp "1"]
[FEN "6k1/pp3p1p/6p1/2pp4/8/2P1P3/PP3PPP/6K1 w - - 0 1"]
