{[%evp 0,138,26,29,10,-23,45,51,57,58,70,10,61,58,50,-27,-27,-6,38,38,34,52,35,
20,64,64,64,64,51,54,12,7,41,11,34,27,64,54,76,76,33,-4,-5,22,0,0,52,78,87,89,
115,83,91,67,42,32,-2,-6,-33,-1,-16,0,-16,-60,-58,-37,-46,-66,0,-46,0,-52,-19,
-142,-128,-147,-105,-265,190,26,192,184,187,181,185,185,184,190,189,213,243,
189,190,189,194,203,217,217,198,185,198,189,189,176,175,171,179,119,142,158,
