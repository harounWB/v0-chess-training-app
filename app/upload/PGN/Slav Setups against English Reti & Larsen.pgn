[ECO "D30"]
[WhiteElo "2503"]
[BlackElo "1996"]
[Annotator "GM Grigor Grigorov"]
[SetUp "1"]
[FEN "r1br2k1/pp2npp1/2n4p/2qp4/8/2N1PN2/PP1QBPPP/3R1RK1 b - - 0 13"]
[PlyCount "74"]
