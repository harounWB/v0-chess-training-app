18,17,17,38,34,43,43,43,42,44,49,57,22,12,-3,-13,-13,-13,-12,-11,-7,3,-10,-7,
-10,-14,-15,-8,-9,-5,-7,-4,-22,-17,-17,-13,-18,-18,-1,-10,-32,-26,-36,0,-24,
-18,-24,-8,-29,-21,-21,-38,-30,-23,-19,-37,-31,-32,-32,-32,0,0,0,0,0,0,0,0,-57,
