{[%evp 0,110,25,19,19,19,19,27,25,6,6,6,35,11,14,1,1,-14,-14,-4,12,12,14,20,16,
0,54,53,81,44,105,117,105,123,126,87,107,80,83,66,78,44,44,15,35,19,58,38,42,
40,40,27,25,34,37,25,36,30,31,7,38,35,22,33,10,17,30,11,52,54,39,7,1,0,5,-4,0,
